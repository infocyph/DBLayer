{
    "name": "infocyph/dblayer",
    "description": "High-performance, secure database layer for PHP and multi-driver capabilities",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "database",
        "query-builder",
        "repository",
        "pdo",
        "sql",
        "mysql",
        "postgresql",
        "sqlite"
    ],
    "authors": [
        {
            "name": "Infocyph",
            "email": "infocyph@gmail.com"
        },
        {
            "name": "abmmhasan",
            "email": "abmmhasan@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "infocyph/arraykit": "^4.1",
        "infocyph/cachelayer": "^1.2",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "infocyph/phpforge": "dev-main"
    },
    "suggest": {
        "ext-pdo_mysql": "For MySQL database support",
        "ext-pdo_pgsql": "For PostgreSQL database support",
        "ext-pdo_sqlite": "For SQLite database support"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Infocyph\\DBLayer\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Infocyph\\DBLayer\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infocyph/phpforge": true,
            "pestphp/pest-plugin": true,
            "pestphp/pest-plugin-drift": true
        },
        "classmap-authoritative": true,
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
