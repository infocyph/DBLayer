{
    "name": "infocyph/dblayer",
    "description": "High-performance, secure database layer for PHP with ORM, async support, and multi-driver capabilities",
    "type": "library",
    "keywords": [
        "database",
        "query-builder",
        "orm",
        "pdo",
        "sql",
        "mysql",
        "postgresql",
        "sqlite",
        "async",
        "swoole"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Hasan",
            "email": "hasan@infocyph.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-pdo": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "suggest": {
        "ext-swoole": "For async query support with Swoole",
        "ext-pdo_mysql": "For MySQL database support",
        "ext-pdo_pgsql": "For PostgreSQL database support",
        "ext-pdo_sqlite": "For SQLite database support"
    },
    "autoload": {
        "psr-4": {
            "Infocyph\\DBLayer\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Infocyph\\DBLayer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test-coverage": "pest --coverage",
        "phpstan": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
